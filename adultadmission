<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Referral Details Form & Report Generator</title>
<style>
body { font-family: Arial, sans-serif; margin: 0; padding: 0; background-color: #f4f4f4; font-size: 16px; }
.container { background-color: #fff; padding: 15px; margin: 10px; border-radius: 8px; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
h1 { text-align: center; margin-top:15px; margin-bottom: 25px; font-size: 1.8em; }
h2, h3, h4, h5 { color: #333; margin-top: 20px; }
h4 { font-size: 1.2em; margin-bottom: 10px;}
h5 { margin-top: 15px; margin-bottom: 8px; font-size: 1.05em; }
fieldset { border: 1px solid #ddd; padding: 15px; margin-bottom: 20px; border-radius: 5px; }
legend { font-weight: bold; color: #555; padding: 0 10px; font-size: 1.1em; }
label { display: block; margin-bottom: 5px; font-weight: 500; }
input[type="text"], input[type="number"], input[type="date"], select, textarea {
    width: 100%; padding: 10px; margin-bottom: 12px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 1em;
}
textarea { min-height: 80px; }
.checkbox-group label, .radio-group label { display: inline-block; margin-right: 15px; margin-bottom: 8px; font-weight: normal;}
.checkbox-group input[type="checkbox"], .radio-group input[type="radio"] { margin-right: 5px; vertical-align: middle; }
.form-row { display: flex; flex-wrap: wrap; gap: 15px; align-items: flex-start; margin-bottom:15px;}
.form-row > div { flex: 1; min-width: 250px;}
.report-output { margin-top: 30px; }
.report-output textarea { width: 100%; height: 520px; font-family: monospace; font-size: 0.9em; }
button#generateReportBtn { background-color: #007bff; color: white; padding: 12px 18px; border: none; border-radius: 4px; cursor: pointer; font-size: 1.1em; display: block; width: 100%; margin-top: 20px; }
button#generateReportBtn:hover { background-color: #0056b3; }
button#copyReportBtn { background-color: #28a745; color: white; padding: 10px 15px; border: none; border-radius: 4px; cursor: pointer; font-size: 1em; margin-top: 10px; }
button#copyReportBtn:hover { background-color: #218838; }
button#resetBtn { background-color: #ff0000; color: white; padding: 10px 15px; border: none; border-radius: 4px; cursor: pointer; font-size: 1em; margin-top: 10px; }
button#resetBtn:hover { background-color: #cc0000; }
#copyMessage { margin-left: 10px; color: green; font-style: italic; display: none; }
.sub-section { margin-left: 10px; border-left: 2px solid #eee; padding-left: 10px; }
.required-asterisk { color: red; margin-left: 2px; }
.small-note { color: #666; font-size: 0.92em; margin-top: -6px; }
@media (max-width: 768px) { .container { margin: 5px; padding: 10px;} .form-row > div { min-width: 100%; } .checkbox-group label, .radio-group label { display: block; margin-right: 0;} }
</style>
</head>
<body>
<div class="container">
<h1>Referral Details Form</h1>
<form id="referralForm">

<fieldset>
<legend>Referral Details</legend>
<div class="form-row">
<div><label for="admissionDate">Date of Admission:</label><input type="date" id="admissionDate"></div>
<div><label for="referralDate">Date of Referral:</label><input type="date" id="referralDate"></div>
<div><label for="intakeDate">Date of Intake:</label><input type="date" id="intakeDate"></div>
</div>
<label for="reasonReferral">Reason for Referral:</label>
<textarea id="reasonReferral" placeholder="According to referral letter"></textarea>
</fieldset>

<fieldset>
<legend>Clinical Information</legend>
<label>Present Diagnosis:</label>
<div class="checkbox-group">
<label><input type="checkbox" name="diagnosis" value="Borderline IQ">Borderline IQ</label>
<label><input type="checkbox" name="diagnosis" value="Mild Learning Disability">Mild Learning Disability</label>
<label><input type="checkbox" name="diagnosis" value="Moderate Learning Disability">Moderate Learning Disability</label>
<label><input type="checkbox" name="diagnosis" value="Severe Learning Disability">Severe Learning Disability</label>
<label><input type="checkbox" name="diagnosis" value="Profound Learning Disability">Profound Learning Disability</label>
<label><input type="checkbox" name="diagnosis" value="ASD">ASD</label>
<label><input type="checkbox" name="diagnosis" value="ADHD">ADHD</label>
<label><input type="checkbox" name="diagnosis" value="Schizophrenia">Schizophrenia</label>
<label><input type="checkbox" name="diagnosis" value="Depression">Depression</label>
<label><input type="checkbox" name="diagnosis" value="BAD">BAD</label>
<label><input type="checkbox" name="diagnosis" value="Dementia">Dementia</label>
</div>
<input type="text" id="diagnosisOther" placeholder="Other diagnosis">
<div class="form-row">
<div><label>SCS Status:</label><div class="radio-group"><label><input type="radio" name="scs" value="Special Care">Special Care</label><label><input type="radio" name="scs" value="Intensive Care">Intensive Care</label><label><input type="radio" name="scs" value="Conventional Care">Conventional Care</label></div></div>
<div><label>Legal Status:</label><div class="radio-group"><label><input type="radio" name="legal" value="Compulsory (F123)">Compulsory (F123)</label><label><input type="radio" name="legal" value="Voluntary">Voluntary</label><label><input type="radio" name="legal" value="Informal">Informal</label></div></div>
</div>
<label>Precautions:</label>
<div class="checkbox-group">
<label><input type="checkbox" name="precautions" value="Suicidal Observation">Suicidal Observation</label>
<label><input type="checkbox" name="precautions" value="Close Observation">Close Observation</label>
<label><input type="checkbox" name="precautions" value="Epilepsy">Epilepsy</label>
<label><input type="checkbox" name="precautions" value="Swallowing">Swallowing</label>
<label><input type="checkbox" name="precautions" value="Infection Control">Infection Control</label>
<label><input type="checkbox" name="precautions" value="Diabetes Mellitus">Diabetes Mellitus</label>
<label><input type="checkbox" name="precautions" value="Fall">Fall</label>
<label><input type="checkbox" name="precautions" value="Violence">Violence</label>
</div>
<label for="reasonAdmission">Reason of Admission:</label><textarea id="reasonAdmission"></textarea>
<label for="psychiatricHistory">Past Psychiatric History:</label>
<textarea id="psychiatricHistory" placeholder="New to Mental Health Service / Known to Mental Health Service since ___ / No past psychiatric admission / __ psychiatric admission / Last admission to ___ during ___"></textarea>
<label for="medicalHistory">Past Medical History:</label><textarea id="medicalHistory"></textarea>
</fieldset>

<fieldset>
<legend>Common Assessment Note - Initial Assessment Report</legend>
<h4>1. Mental State and General Observations</h4>
<div class="form-row"><div><label>Seen patient at <span class="required-asterisk">*</span>:</label><input type="text" id="seenTime" placeholder="e.g. 10:30 am"></div></div>
<label>General Observation:</label><div class="checkbox-group" id="generalObservationGroup"></div>
<label>Mood:</label><div class="checkbox-group" id="moodGroup"></div>
<label>Affect:</label><div class="checkbox-group" id="affectGroup"></div>
<label>Speech:</label><div class="checkbox-group" id="speechGroup"></div>
<label>Hallucination:</label><div class="checkbox-group" id="hallucinationGroup"></div>
<label>Abnormal Thought:</label><div class="checkbox-group" id="thoughtGroup"></div>
<label>Suicidal / Negative Thought:</label><div class="checkbox-group"><label><input type="checkbox" name="suicidalNegative" value="Expressed suicidal thought">Expressed suicidal thought</label><label><input type="checkbox" name="suicidalNegative" value="Negative cognition of sense of uselessness">Negative cognition of sense of uselessness</label><label><input type="checkbox" name="suicidalNegative" value="Hopelessness">Hopelessness</label><label><input type="checkbox" name="suicidalNegative" value="Helplessness">Helplessness</label><label><input type="checkbox" name="suicidalNegative" value="Worthlessness">Worthlessness</label><label><input type="checkbox" name="suicidalNegative" value="Denied suicidal / negative thought">Denied suicidal / negative thought</label></div>
<div class="form-row"><div><label>Sleep:</label><select id="sleep"><option value=""></option><option>good</option><option>fair</option><option>poor</option></select></div><div><label>Appetite:</label><select id="appetite"><option value=""></option><option>good</option><option>fair</option><option>poor</option></select></div></div>
<label>Orientation:</label><div class="radio-group"><label><input type="radio" name="orientation" value="Orientated to time, place and person">Orientated to time, place and person</label><label><input type="radio" name="orientation" value="Disorientated">Disorientated</label></div>
<label>Insight:</label><div class="radio-group"><label><input type="radio" name="insight" value="full">Full</label><label><input type="radio" name="insight" value="partial">Partial</label><label><input type="radio" name="insight" value="limited">Limited</label><label><input type="radio" name="insight" value="poor">Poor</label></div>
<label for="mseRemarks">Mental State Remarks:</label><textarea id="mseRemarks"></textarea>

<h4>2. Psychosocial Status and Functional Performance</h4>
<h5>Psychosocial Status</h5>
<div class="form-row"><div><label>Marital Status:</label><select id="marital"><option value=""></option><option>Single</option><option>Married</option><option>Divorced</option><option>Widow</option><option>Widower</option></select></div><div><label>Living with:</label><div class="checkbox-group"><label><input type="checkbox" name="livingWith" value="Alone">Alone</label><label><input type="checkbox" name="livingWith" value="Family">Family</label><label><input type="checkbox" name="livingWith" value="Maid">Maid</label><label><input type="checkbox" name="livingWith" value="Others">Others</label></div><input type="text" id="livingDetails" placeholder="Details"></div></div>
<label>Role:</label><div class="checkbox-group"><label><input type="checkbox" name="role" value="Caregiver">Caregiver</label><label><input type="checkbox" name="role" value="Homemaker">Homemaker</label><label><input type="checkbox" name="role" value="Self maintainer">Self maintainer</label><label><input type="checkbox" name="role" value="Care Recipient">Care Recipient</label></div>
<label>Community Service:</label><div class="checkbox-group"><label><input type="checkbox" name="communityService" value="Integrated Community Centre for Mental Wellness (ICCMW)">ICCMW</label><label><input type="checkbox" name="communityService" value="OT OPD">OT OPD</label><label><input type="checkbox" name="communityService" value="Community Psychiatric Service (CPN)">CPN</label></div>
<label>Financial Support:</label><div class="checkbox-group"><label><input type="checkbox" name="financialSupport" value="CSSA">CSSA</label><label><input type="checkbox" name="financialSupport" value="DA">DA</label><label><input type="checkbox" name="financialSupport" value="OALA">OALA</label><label><input type="checkbox" name="financialSupport" value="Pension or Saving">Pension or Saving</label><label><input type="checkbox" name="financialSupport" value="Family">Family</label></div>

<h5>Functional Performance</h5>
<div class="form-row"><div><label>ADL:</label><select id="adlLevel"><option value=""></option><option>Independent</option><option>Supervised</option><option>Assisted</option><option>Dependent</option></select><input type="text" id="adlIssues" placeholder="Poor hygiene / poor habit in ___ tasks"></div><div><label>IADL:</label><select id="iadlLevel"><option value=""></option><option>Independent</option><option>Supervised by</option><option>Assisted by</option><option>Dependent on</option><option>Shared with</option></select><input type="text" id="iadlDetails" placeholder="Responsible for ___ tasks / supervised by ___"></div></div>

<h5>Education and Work</h5>
<div class="form-row"><div><label>Education Level:</label><select id="education"><option value=""></option><option>primary</option><option>secondary</option><option>tertiary</option><option>university</option></select><input type="text" id="educationQuitReason" placeholder="Quitted due to ___"></div><div><label>Employment Status:</label><input type="text" id="employmentStatus" placeholder="Employed / Unemployed for ___ / Retired for ___"><input type="text" id="currentEmployment" placeholder="Current employment"></div></div>
<label for="workHistory">Work History:</label><textarea id="workHistory" placeholder="Never gainfully employed / unstable job record / longest job..."></textarea>
<label for="quitReason">Reason on quitting the job:</label><textarea id="quitReason"></textarea>
<label>Vocational training received:</label><div class="checkbox-group"><label><input type="checkbox" name="vocTraining" value="Supported Employment">Supported Employment</label><label><input type="checkbox" name="vocTraining" value="Sunny-way program">Sunny-way program</label><label><input type="checkbox" name="vocTraining" value="On-the-job training">On-the-job training</label><label><input type="checkbox" name="vocTraining" value="ERB course">ERB course</label><label><input type="checkbox" name="vocTraining" value="Vocational Training Council (VTC) program">VTC</label><label><input type="checkbox" name="vocTraining" value="Teen才再現計劃 (Youth College)">Teen才再現計劃</label></div>
<label for="rtwReadiness">Readiness in returning to work / study:</label><textarea id="rtwReadiness"></textarea>

<h5>Childcare Performance</h5>
<label for="childBackground">Child's Background:</label><textarea id="childBackground"></textarea>
<label for="childcareRole">Childcare Role:</label><input type="text" id="childcareRole" placeholder="Major / supported role in childcare">
<label for="childcareStressBarrier">Childcare Stress / Barrier:</label><textarea id="childcareStressBarrier"></textarea>
<label for="childcareSupport">Childcare Support:</label><textarea id="childcareSupport"></textarea>
<h5>Leisure</h5>
<label for="hobbies">Hobbies:</label><textarea id="hobbies"></textarea>
<label for="interest">Interest:</label><textarea id="interest"></textarea>
<label for="daytimeEngagement">Daytime engagement:</label><textarea id="daytimeEngagement" placeholder="Types of activities / Frequency / Duration / Enjoyment level"></textarea>
<label for="leisureBarriers">Barriers:</label><textarea id="leisureBarriers"></textarea>
<h5>Social</h5>
<textarea id="social" placeholder="Relationship with family / peer / barriers"></textarea>
<h5>Stress Coping</h5>
<div class="checkbox-group"><label><input type="checkbox" name="coping" value="Bottle-up feeling">Bottle-up feeling</label><label><input type="checkbox" name="coping" value="Ventilation to friends / family members">Ventilation to friends / family members</label><label><input type="checkbox" name="coping" value="Leisure activities">Leisure activities</label><label><input type="checkbox" name="coping" value="Seek help from CPN / ICCMW worker / IFSC worker">Seek help from CPN / ICCMW / IFSC</label><label><input type="checkbox" name="coping" value="Maladaptive coping of drinking / overdosing / self-harm behaviour / temper outburst / aggression">Maladaptive coping</label></div>
<input type="text" id="copingDetails" placeholder="Details">

<h4>3. Assessment Result</h4>
<h5>Well-being - C-SWEMWBS</h5>
<div class="form-row"><div><label>Date:</label><input type="date" id="wellbeingDate"></div><div><label>Score /35:</label><input type="number" id="wellbeingScore" min="0" max="35"></div></div>
<div class="form-row"><div><label>Optimism and Future Orientation:</label><select id="optimism"><option value=""></option><option>Good</option><option>Fair</option><option>Poor</option></select></div><div><label>Sense of Usefulness and Purpose:</label><select id="usefulness"><option value=""></option><option>Good</option><option>Fair</option><option>Poor</option></select></div><div><label>Relaxation and Stress Management:</label><select id="relaxation"><option value=""></option><option>Good</option><option>Fair</option><option>Poor</option></select></div></div>
<div class="form-row"><div><label>Problem Solving and Coping:</label><select id="problemSolving"><option value=""></option><option>Good</option><option>Fair</option><option>Poor</option></select></div><div><label>Clarity of Thinking:</label><select id="clarity"><option value=""></option><option>Good</option><option>Fair</option><option>Poor</option></select></div><div><label>Connectedness and Relationships:</label><select id="connectedness"><option value=""></option><option>Good</option><option>Fair</option><option>Poor</option></select></div><div><label>Autonomy and Self Determination:</label><select id="autonomy"><option value=""></option><option>Good</option><option>Fair</option><option>Poor</option></select></div></div>

<h5>Cognitive Function - B-MCCB</h5>
<div class="form-row"><div><label>B-MCCB Date:</label><input type="date" id="bmccbDate"></div></div>
<div class="form-row"><div><label>TMT Part A T-score / Percentile / Descriptor:</label><input type="text" id="tmt"></div><div><label>BACS Symbol Coding:</label><input type="text" id="bacs"></div><div><label>Category Fluency:</label><input type="text" id="fluency"></div></div>
<label for="processingSpeed">Overall Performance in Speeding of Processing:</label><textarea id="processingSpeed"></textarea>
<label for="otherAssessment">Other assessment templates / results:</label><textarea id="otherAssessment"></textarea>

<h4>4. Home Environment</h4>
<div class="form-row"><div><label>Accommodation:</label><select id="accommodation"><option value=""></option><option>PHU</option><option>HOS Flat</option><option>Private flat</option><option>OAH</option><option>C&A Home</option><option>Village House or Hut</option><option>Other</option></select></div></div>
<label>Accessibility:</label><div class="checkbox-group"><label><input type="checkbox" name="accessibility" value="G/F">G/F</label><label><input type="checkbox" name="accessibility" value="Direct lift-landing">Direct lift-landing</label><label><input type="checkbox" name="accessibility" value="Non-direct lift-landing FOS">Non-direct lift-landing FOS</label><label><input type="checkbox" name="accessibility" value="Non-lift landing FOS">Non-lift landing FOS</label><label><input type="checkbox" name="accessibility" value="Slopes">Slopes</label><label><input type="checkbox" name="accessibility" value="Uneven ground">Uneven ground</label></div><input type="text" id="accessibilityDetails" placeholder="_ steps / other accessibility details">
<label>Toilet:</label><div class="checkbox-group"><label><input type="checkbox" name="toilet" value="Sitting">Sitting</label><label><input type="checkbox" name="toilet" value="Squatting">Squatting</label><label><input type="checkbox" name="toilet" value="Commode">Commode</label><label><input type="checkbox" name="toilet" value="Urinal or bedpan">Urinal or bedpan</label><label><input type="checkbox" name="toilet" value="Napkin">Napkin</label></div><input type="text" id="toiletDetails" placeholder="Other toilet details">
<label>Bathroom:</label><div class="checkbox-group"><label><input type="checkbox" name="bathroom" value="Shower">Shower</label><label><input type="checkbox" name="bathroom" value="Bathtub">Bathtub</label><label><input type="checkbox" name="bathroom" value="Shower Tub">Shower Tub</label><label><input type="checkbox" name="bathroom" value="Basin">Basin</label><label><input type="checkbox" name="bathroom" value="Bucket">Bucket</label><label><input type="checkbox" name="bathroom" value="Shower chair">Shower chair</label><label><input type="checkbox" name="bathroom" value="Hot water system">Hot water system</label></div><input type="text" id="bathroomDetails" placeholder="Other bathroom details">
<div class="form-row"><div><label>Aid/Equipment:</label><input type="text" id="aidEquipment" placeholder="Handrail / Bedrail / Commode Chair / Others"></div></div>

<h4>5. Caregiver's Concern</h4>
<textarea id="caregiverConcern" placeholder="ADL/IADL/Childcare/Cognitive/Social/Financial/Lifestyle/Illness management/Behavioral aspects; own health issue"></textarea>

<h4>6. Family's / Client's Goals</h4>
<h5>Illness Management</h5><div class="checkbox-group"><label><input type="checkbox" name="goalIllness" value="Symptom control">Symptom control</label><label><input type="checkbox" name="goalIllness" value="Medication adherence">Medication adherence</label></div>
<h5>Functional Independence</h5><div class="checkbox-group"><label><input type="checkbox" name="goalFunctional" value="ADL independence">ADL independence</label><label><input type="checkbox" name="goalFunctional" value="IADL competence">IADL competence</label><label><input type="checkbox" name="goalFunctional" value="Work Capability">Work Capability</label><label><input type="checkbox" name="goalFunctional" value="Childcare Competence">Childcare Competence</label></div>
<h5>Psychosocial Well-being</h5><div class="checkbox-group"><label><input type="checkbox" name="goalPsychosocial" value="Reduce isolation">Reduce isolation</label><label><input type="checkbox" name="goalPsychosocial" value="Engage socially">Engage socially</label><label><input type="checkbox" name="goalPsychosocial" value="Improve mood">Improve mood</label><label><input type="checkbox" name="goalPsychosocial" value="Maintain hobbies">Maintain hobbies</label></div>
<input type="text" id="goalDetails" placeholder="Other goals / details">
</fieldset>

<fieldset>
<legend>Psychiatric Assessment Note</legend>
<h4>Overall Level of Functioning</h4>
<div class="form-row"><div><label>SOFAS Date:</label><input type="date" id="sofasDate"></div><div><label>SOFAS Score /100:</label><input type="number" id="sofasScore" min="0" max="100"></div></div>
<div class="form-row"><div><label>CGAS Date:</label><input type="date" id="cgasDate"></div><div><label>CGAS Score /100:</label><input type="number" id="cgasScore" min="1" max="100"></div></div>
</fieldset>

<fieldset>
<legend>Problem(s)</legend>
<div class="checkbox-group" id="problemsGroup"></div>
<textarea id="problemOthers" placeholder="Other problem(s)"></textarea>
</fieldset>

<fieldset>
<legend>Recommendation(s)</legend>
<div class="checkbox-group" id="recommendationsGroup"></div>
<textarea id="recommendationOthers" placeholder="Other recommendation(s)"></textarea>
</fieldset>

<button type="button" id="generateReportBtn" onclick="generateReport()">Generate Report</button>
<button type="button" id="resetBtn" onclick="resetForm()">Reset Form</button>
</form>

<div class="report-output">
<h2>Generated Referral Details Report</h2>
<textarea id="reportOutput" readonly></textarea>
<button id="copyReportBtn" onclick="copyReport()">Copy Report</button><span id="copyMessage">Copied!</span>
</div>
</div>

<script>
function addCheckboxes(containerId, name, values) {
    const container = document.getElementById(containerId);
    values.forEach(v => {
        const label = document.createElement('label');
        label.innerHTML = `<input type="checkbox" name="${name}" value="${escapeHtml(v)}">${v}`;
        container.appendChild(label);
    });
}
function escapeHtml(str) { return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
function getVal(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }
function getCheckedValues(name) { return Array.from(document.querySelectorAll(`input[name="${name}"]:checked`)).map(cb => cb.value); }
function getRadioValue(name) { const el = document.querySelector(`input[name="${name}"]:checked`); return el ? el.value : ''; }
function formatDate(dateString) { if (!dateString) return ''; const [y, m, d] = dateString.split('-'); return `${d}/${m}/${y}`; }
function line(label, value) { return value ? `${label}: ${value}\n` : ''; }
function bullet(value) { return value ? `- ${value}\n` : ''; }
function listOrBlank(arr, other) { const items = [...arr]; if (other) items.push(other); return items.join(' / '); }
function sofasDescriptor(score) {
    const n = Number(score);
    if (Number.isNaN(n)) return '';
    if (n >= 91) return 'SUPERIOR FUNCTIONING in wide range of activities.';
    if (n >= 81) return 'GOOD FUNCTIONING in all areas, occupationally and socially effective.';
    if (n >= 71) return 'SLIGHT IMPAIRMENT in social or occupational or school functioning (e.g. infrequent interpersonal conflict, temporarily failing behind in schoolwork).';
    if (n >= 61) return 'SOME DIFFICULTY in social, occupational, or school functioning, but generally functioning well, has some meaningful interpersonal relationships.';
    if (n >= 51) return 'MODERATE DIFFICULTY in social, occupational, or school functioning (e.g. few friends, conflicts with peers, or co-workers).';
    if (n >= 41) return 'SERIOUS IMPAIRMENT in social, occupational, or school functioning (e.g. no friends, unable to keep a job) in some areas.';
    if (n >= 31) return 'MAJOR IMPAIRMENT IN SEVERAL AREAS, such as work or school, family relations (e.g. depressed man avoids friends, neglects family, and is unable to work; child frequently beats up younger children, is defiant at home, and failing at school).';
    if (n >= 21) return 'INABILITY TO FUNCTION socially or occupationally in almost all areas (e.g. stays in bed all day, no job, home, or friends).';
    if (n >= 11) return 'OCCASIONALLY HYGIENE PROBLEMS, fails to maintain minimal personal hygiene, unable to function independently.';
    if (n >= 1) return 'PERSISTENT HYGIENE PROBLEMS, inability to maintain minimal personal hygiene. Unable to function without harming self or others or without considerable external support (e.g. nursing care and supervision).';
    if (n === 0) return 'Inadequate Information';
    return '';
}
function cgasDescriptor(score) {
    const n = Number(score);
    if (Number.isNaN(n)) return '';
    if (n >= 91) return 'Superior functioning in all areas (at home, at school and with peers); involved in a wide range of activities and has many interests; likeable, confident; everyday worries never get out of hand; doing well in school; no symptoms.';
    if (n >= 81) return 'Good functioning in all areas; secure in family, school, and with peers; there may be transient difficulties and everyday worries that occasionally get out of hand.';
    if (n >= 71) return 'No more than slight impairments in functioning at home, at school, or with peers; disturbance of behaviour or emotional distress may be present in response to life stresses, but interference with functioning is transient.';
    if (n >= 61) return 'Some difficulty in single area but generally functioning pretty well; has some meaningful interpersonal relationships; familiar people might express concern.';
    if (n >= 51) return 'Variable functioning with sporadic difficulties or symptoms in several but not all social areas; disturbance would be apparent to those who encounter the child in a dysfunctional setting or time.';
    if (n >= 41) return 'Moderate degree of interference in functioning in most social areas or severe impairment of functioning in one area, such as suicidal preoccupations, school refusal, anxiety, obsessive rituals, conversion symptoms, anxiety attacks, poor social skills, or frequent aggressive or antisocial behaviour with some preservation of meaningful social relationships.';
    if (n >= 31) return 'Major impairment of functioning in several areas and unable to function in one of these areas, such as disturbed at home, at school, with peers, or in society at large; such children are likely to require special schooling and/or hospitalisation or withdrawal from school.';
    if (n >= 21) return 'Unable to function in almost all areas e.g., stays at home, in ward, or in bed all day without taking part in social activities or severe impairment in reality testing or serious impairment in communication.';
    if (n >= 11) return 'Needs considerable supervision to prevent hurting others or self or to maintain personal hygiene, or has gross impairment in all forms of communication.';
    if (n >= 1) return 'Needs constant supervision (24-hour care) due to severely aggressive or self-destructive behaviour or gross impairment in reality testing, communication, cognition, affect or personal hygiene.';
    return '';
}

