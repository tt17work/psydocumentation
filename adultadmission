function generateReport() {
    let report = '';
    report += '[Referral Details]\n';
    report += `Date of Admission / Referral / Intake: ${formatDate(getVal('admissionDate')) || '_____'} / ${formatDate(getVal('referralDate')) || '_____'} / ${formatDate(getVal('intakeDate')) || '_____'}\n\n`;

    report += '[Reason for Referral]\n';
    report += `${getVal('reasonReferral') || '(according to referral letter)'}\n\n`;

    report += '[Clinical Information]\n';
    report += line('Present Diagnosis', listOrBlank(getCheckedValues('diagnosis'), getVal('diagnosisOther')) || '_____');
    report += line('SCS Status', getRadioValue('scs'));
    report += line('Legal Status', getRadioValue('legal'));
    report += line('Precautions', listOrBlank(getCheckedValues('precautions')));
    report += line('Reason of Admission', getVal('reasonAdmission'));
    report += line('Past Psychiatric History', getVal('psychiatricHistory'));
    report += line('Past Medical History', getVal('medicalHistory')) + '\n';

    report += '[Common Assessment Note]\n<<Initial Assessment Report>>\n';
    report += '1. Mental State and General Observations\n';
    report += bullet(`Seen patient at ${getVal('seenTime') || '____'}`);
    report += bullet(getCheckedValues('generalObservation').join(' / '));
    report += bullet(getCheckedValues('mood').length ? `Mood ${getCheckedValues('mood').join(' / ')}` : '');
    report += bullet(getCheckedValues('affect').length ? `Affect ${getCheckedValues('affect').join(' / ')}` : '');
    report += bullet(getCheckedValues('speech').length ? `Speech ${getCheckedValues('speech').join(' / ')}` : '');
    report += bullet(getCheckedValues('hallucination').join(' / '));
    report += bullet(getCheckedValues('thought').join(' / '));
    report += bullet(getCheckedValues('suicidalNegative').join(' / '));
    const sleepApp = [getVal('sleep') ? `${getVal('sleep')} sleep` : '', getVal('appetite') ? `${getVal('appetite')} appetite` : ''].filter(Boolean).join(' and ');
    report += bullet(sleepApp ? `Reported of ${sleepApp}` : '');
    report += bullet(getRadioValue('orientation'));
    report += bullet(getRadioValue('insight') ? `Insight ${getRadioValue('insight')}` : '');
    report += getVal('mseRemarks') ? `Remarks: ${getVal('mseRemarks')}\n` : '';

    report += '\n2. Psychosocial Status and Functional Performance\n<Psychosocial Status>\n';
    report += line('Marital Status', getVal('marital'));
    report += line('Living with', listOrBlank(getCheckedValues('livingWith'), getVal('livingDetails')));
    report += line('Role', getCheckedValues('role').join(' / '));
    report += line('Community Service', getCheckedValues('communityService').join(' / '));
    report += line('Financial Support', getCheckedValues('financialSupport').join(' / '));

    report += '\n<Functional Performance>\n';
    report += line('<ADL>', [getVal('adlLevel'), getVal('adlIssues')].filter(Boolean).join(' - '));
    report += line('<IADL>', [getVal('iadlLevel'), getVal('iadlDetails')].filter(Boolean).join(' - '));

    report += '\n<Education and Work>\n';
    report += line('Education', [getVal('education') ? `Educated up to ${getVal('education')} level` : '', getVal('educationQuitReason') ? `quitted due to ${getVal('educationQuitReason')}` : ''].filter(Boolean).join('; '));
    report += line('Employment Status', getVal('employmentStatus'));
    report += line('Current Employment', getVal('currentEmployment'));
    report += line('Work History', getVal('workHistory'));
    report += line('Reason on quitting the job', getVal('quitReason'));
    report += line('Vocational training received', getCheckedValues('vocTraining').join(' / '));
    report += line('Readiness in returning to work / study', getVal('rtwReadiness'));

    const childcareLines = [
        line("Child's Background", getVal('childBackground')),
        line('Childcare Role', getVal('childcareRole')),
        line('Childcare Stress / Barrier', getVal('childcareStressBarrier')),
        line('Childcare Support', getVal('childcareSupport'))
    ].join('');
    if (childcareLines) report += '\n<Childcare Performance>\n' + childcareLines;

    const leisureLines = [
        line('Hobbies', getVal('hobbies')),
        line('Interest', getVal('interest')),
        line('Daytime engagement', getVal('daytimeEngagement')),
        line('Barriers', getVal('leisureBarriers'))
    ].join('');
    if (leisureLines) report += '\n<Leisure>\n' + leisureLines;
    report += line('\n<Social>', getVal('social'));
    report += line('\n<Stress Coping>', listOrBlank(getCheckedValues('coping'), getVal('copingDetails')));

    let sectionNo = 3;
    const assessmentFields = ['wellbeingDate','wellbeingScore','optimism','usefulness','relaxation','problemSolving','clarity','connectedness','autonomy','bmccbDate','tmt','bacs','fluency','processingSpeed','otherAssessment'];
    const hasAssessment = assessmentFields.some(id => getVal(id));
    if (hasAssessment) {
        report += `\n${sectionNo++}. Assessment Result\n`;
        if (['wellbeingDate','wellbeingScore','optimism','usefulness','relaxation','problemSolving','clarity','connectedness','autonomy'].some(id => getVal(id))) {
            report += '<Well-being>\nThe Chinese Version of The Short Warwick-Edinburgh Mental Well-being Scale (C-SWEMWBS)\n';
            report += `Date: ${formatDate(getVal('wellbeingDate')) || ''} ${getVal('wellbeingScore') ? getVal('wellbeingScore') + '/35' : ''}\n\nDescription:\n`;
            [['Optimism and Future Orientation','optimism'],['Sense of Usefulness and Purpose','usefulness'],['Relaxation and Stress Management','relaxation'],['Problem Solving and Coping','problemSolving'],['Clarity of Thinking','clarity'],['Connectedness and Relationships','connectedness'],['Autonomy and Self Determination','autonomy']].forEach(([labelText, id]) => { report += line(labelText, getVal(id)); });
        }
        if (['bmccbDate','tmt','bacs','fluency','processingSpeed','otherAssessment'].some(id => getVal(id))) {
            report += '\n<Cognitive Function>\nBrief MATRICS Consensus Cognitive Battery (B-MCCB) was done on ' + (formatDate(getVal('bmccbDate')) || '___') + '\n';
            report += line('- Trail Making Test (TMT): Part A', getVal('tmt'));
            report += line('- BACS: Symbol Coding', getVal('bacs'));
            report += line('- Category Fluency: Animal Naming', getVal('fluency'));
            report += line('- Overall Performance in Speeding of Processing', getVal('processingSpeed'));
            report += line('Other assessment templates / results', getVal('otherAssessment'));
        }
    }

    const homeLines = [
        line('Accommodation', getVal('accommodation')),
        line('Accessibility', listOrBlank(getCheckedValues('accessibility'), getVal('accessibilityDetails'))),
        line('Toilet', listOrBlank(getCheckedValues('toilet'), getVal('toiletDetails'))),
        line('Bathroom', listOrBlank(getCheckedValues('bathroom'), getVal('bathroomDetails'))),
        line('Aid/Equipment', getVal('aidEquipment'))
    ].join('');
    if (homeLines) report += `\n${sectionNo++}. Home Environment\n` + homeLines;

    if (getVal('caregiverConcern')) report += `\n${sectionNo++}. Caregiver’s Concern\n` + getVal('caregiverConcern') + '\n';

    const goalLines = [];
    if (getCheckedValues('goalIllness').length) goalLines.push('Illness Management: ' + getCheckedValues('goalIllness').join(' / '));
    if (getCheckedValues('goalFunctional').length) goalLines.push('Functional Independence: ' + getCheckedValues('goalFunctional').join(' / '));
    if (getCheckedValues('goalPsychosocial').length) goalLines.push('Psychosocial Well-being: ' + getCheckedValues('goalPsychosocial').join(' / '));
    if (getVal('goalDetails')) goalLines.push('Other goals / details: ' + getVal('goalDetails'));
    if (goalLines.length) report += `\n${sectionNo++}. Family’s / Client’s Goals\n` + goalLines.join('\n') + '\n\n';

    const sofas = getVal('sofasScore');
    const cgas = getVal('cgasScore');
    if (sofas || cgas || getVal('sofasDate') || getVal('cgasDate')) {
        report += '[Psychiatric Assessment Note]\n<Overall Level of Functioning>\n';
        if (sofas || getVal('sofasDate')) {
            report += `Social and Occupational Functioning Assessment Scale (SOFAS)\nDate: ${formatDate(getVal('sofasDate')) || ''} ${sofas ? sofas + '/100' : ''}\n`;
            if (sofas) report += `Description: ${sofasDescriptor(sofas)}\n`;
        }
        if (cgas || getVal('cgasDate')) {
            report += `Children’s Global Assessment Scale (CGAS)\nDate: ${formatDate(getVal('cgasDate')) || ''} ${cgas ? cgas + '/100' : ''}\n`;
            if (cgas) report += `Description: ${cgasDescriptor(cgas)}\n`;
        }
        report += '\n';
    }

    report += '[Problem(s)]\n';
    const problems = listOrBlank(getCheckedValues('problems'), getVal('problemOthers'));
    report += problems ? problems.split(' / ').map(p => '- ' + p).join('\n') + '\n\n' : '\n';

    report += '[Recommendation(s)]\n';
    const recs = listOrBlank(getCheckedValues('recommendations'), getVal('recommendationOthers'));
    report += recs ? recs.split(' / ').map(r => '- ' + r).join('\n') + '\n' : '';

    document.getElementById('reportOutput').value = report.replace(/\n{3,}/g, '\n\n');
}
function copyReport() {
    const reportOutput = document.getElementById('reportOutput');
    reportOutput.select();
    reportOutput.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(reportOutput.value).then(() => {
        const msg = document.getElementById('copyMessage');
        msg.style.display = 'inline';
        setTimeout(() => msg.style.display = 'none', 2000);
    });
}
function resetForm() {
    if (confirm('Reset all fields?')) {
        document.getElementById('referralForm').reset();
        document.getElementById('reportOutput').value = '';
    }
}
</script>
